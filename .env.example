# ---------------------------------------------------------------------------
# Sentinel — environment configuration
#
# Copy this file to ".env" and fill in the keys for the providers you use:
#     cp .env.example .env
#
# The ".env" file is git-ignored, so your secrets never reach version control.
# You only need keys for the providers you actually plan to select. Any key
# left unset can still be entered interactively when you pick that provider.
# ---------------------------------------------------------------------------

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI (GPT)
OPENAI_API_KEY=sk-your-openai-key-here

# Google Gemini (via its OpenAI-compatible endpoint)
GEMINI_API_KEY=your-gemini-key-here

# OpenRouter (gateway to many providers/models)
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# Local Ollama — no key needed. Override only if not on the default host.
# OLLAMA_HOST=http://localhost:11434/v1

# Custom OpenAI-compatible provider (you supply the URL + key).
# These prefill the prompts when you select the "Custom" provider.
# CUSTOM_BASE_URL=https://your-endpoint.example.com/v1
# CUSTOM_API_KEY=your-custom-key-here

# Optional: provider + model to pre-select on startup (skips the menus).
# Provider keys: anthropic | openai | gemini | openrouter | ollama | custom
# SENTINEL_PROVIDER=anthropic
# SENTINEL_MODEL=claude-sonnet-4-6
